---
import { ViewTransitions } from 'astro:transitions';
import SearchPortal from '../components/SearchPortal.tsx';
import AccountButton from '../components/AccountButton.tsx';

interface Props {
  title: string;
  showPortal?: boolean;
}

const { title, showPortal = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link href="https://fonts.googleapis.com/css2?family=Alegreya+Sans:wght@400;500;700&display=swap" rel="stylesheet">
  <ViewTransitions fallback="none" />
  <style is:inline>
    ::view-transition-old(root),
    ::view-transition-new(root) {
      animation-duration: 100ms;
    }
  </style>
  <style is:global>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: "Alegreya Sans", system-ui, sans-serif;
      background: #d4cfc4;
      min-height: 100vh;
      padding: 12px;
    }
    a { color: #1a1a1a; }
    a:hover { color: #5a5549; }
    .container {
      max-width: 960px;
      margin: 0 auto;
      background: #f5f0e6;
      border: 1px solid #000;
      padding: 20px;
      min-height: calc(100vh - 24px);
      display: flex;
      flex-direction: column;
    }
    .content {
      flex: 1;
    }
    header {
      display: flex;
      align-items: center;
      gap: 15px;
      margin-bottom: 20px;
      flex-wrap: wrap;
    }
    .header-top {
      display: contents;
    }
    .header-right {
      order: 3;
    }
    .search-portal-container {
      order: 2;
    }
    @media (max-width: 600px) {
      .header-top {
        display: flex;
        align-items: center;
        width: 100%;
        gap: 15px;
      }
      .header-right {
        order: unset;
        margin-left: auto;
      }
      .search-portal-container {
        order: unset;
        width: 100%;
        margin-top: 5px;
      }
    }
    header h1 {
      font-weight: 500;
      margin: 0;
    }
    header h1 a {
      text-decoration: none;
      color: inherit;
    }
    header h1 em {
      font-style: italic;
      margin-right: 3px;
    }
    header h1 u {
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    header h1 a:hover {
      color: #5a5549;
    }
    .search-portal-container {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      flex: 1;
    }
    .search-portal {
      font-size: 13px;
      color: #5a5549;
      text-decoration: none;
      padding: 3px 8px;
      border: 1px solid #d9d4c8;
      background: #faf6ed;
    }
    .search-portal:hover {
      background: #f0ebdf;
      border-color: #5a5549;
    }
    .search-portal.current {
      border-color: #5a5549;
      background: #f0ebdf;
    }
    .search-portal-clear {
      font-size: 14px;
      color: #a65d57;
      background: #f5ebe9;
      border: 1px solid #d4b5b1;
      cursor: pointer;
      padding: 3px 8px;
      line-height: 1;
    }
    .search-portal-clear:hover {
      color: #8b3a33;
      background: #f0dcd8;
      border-color: #a65d57;
    }
    h2 { font-weight: 500; font-size: 1.2em; margin: 20px 0 10px; }

    /* Account */
    .account-text { font-size: 14px; color: #5a5549; }
    .account-link { font-size: 14px; color: #5a5549; text-decoration: underline; text-underline-offset: 2px; }
    .account-sep { color: #a9a49a; }

    /* Reading status buttons */
    .status-btns { display: inline-flex; gap: 4px; margin-left: 8px; }
    .status-btn {
      font-size: 11px;
      padding: 2px 6px;
      border: 1px solid #d9d4c8;
      background: #faf6ed;
      color: #8a8477;
      cursor: pointer;
      font-family: inherit;
    }
    .status-btn:hover { border-color: #5a5549; }
    .status-btn-active {
      border-color: #5a5549;
      background: #5a5549;
      color: #fff;
    }
    .status-btn-dnf {
      border-color: #a65d57;
      background: #a65d57;
      color: #fff;
    }

    /* Reading shelves */
    .shelves { margin-top: 30px; }
    .shelf { margin-bottom: 25px; }
    .shelf-title {
      font-size: 14px;
      font-weight: 500;
      color: #5a5549;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 12px;
    }
    .shelf-books {
      display: flex;
      gap: 15px;
      overflow-x: auto;
      padding-bottom: 10px;
    }
    .shelf-book {
      flex-shrink: 0;
      width: 80px;
      text-decoration: none;
      color: inherit;
    }
    .shelf-book:hover .shelf-book-title { color: #5a5549; }
    .shelf-cover {
      width: 80px;
      height: 120px;
      object-fit: cover;
      background: #e8e4d9;
      display: block;
    }
    .shelf-cover-placeholder {
      width: 80px;
      height: 120px;
      background: #e8e4d9;
    }
    .shelf-book-title {
      font-size: 12px;
      margin-top: 6px;
      line-height: 1.3;
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <div class="header-top">
        <h1><a href="/" id="logo"><em>my</em><u>lib</u></a></h1>
        <div class="header-right">
          <AccountButton client:only="react" />
        </div>
      </div>
      {showPortal && <SearchPortal client:only="react" />}
    </header>
    <div class="content">
      <slot />
    </div>
  </div>
  <script>
    import { clearSearch } from '../stores/search';

    function setupLogo() {
      document.getElementById('logo')?.addEventListener('click', () => {
        clearSearch();
      });
    }
    setupLogo();
    document.addEventListener('astro:page-load', setupLogo);
  </script>
</body>
</html>
