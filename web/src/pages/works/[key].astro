---
import Layout from '../../layouts/Layout.astro';
import ReadingStatus from '../../components/ReadingStatus.tsx';

const API_BASE = import.meta.env.API_URL || 'http://localhost:3000';
const { key } = Astro.params;

const res = await fetch(`${API_BASE}/works/${key}`);
if (!res.ok) {
  return Astro.redirect('/404');
}
const { authors, editions, ...work } = await res.json();

// Find first edition with a cover for the main image
const mainCoverId = editions.find(e => e.cover_id)?.cover_id;
const ogImage = mainCoverId ? `https://covers.openlibrary.org/b/id/${mainCoverId}-L.jpg` : undefined;
const authorList = authors.map(a => a.name).join(', ');
const ogDescription = work.description
  ? work.description.slice(0, 200) + (work.description.length > 200 ? '...' : '')
  : authorList ? `By ${authorList}` : undefined;

// Cache for 1 hour, stale-while-revalidate for 1 day
Astro.response.headers.set('Cache-Control', 'public, max-age=3600, stale-while-revalidate=86400');

function esc(str) {
  if (!str) return '';
  return str.replace(/[\uFE20\uFE21]/g, '');
}
---

<Layout title={work.title} description={ogDescription} image={ogImage} type="book" showPortal>
  <div class="work-header">
    {mainCoverId && (
      <img
        src={`https://covers.openlibrary.org/b/id/${mainCoverId}-M.jpg`}
        alt=""
        width="120"
        height="180"
        class="work-cover"
      />
    )}
    <div class="work-info">
      <h2 class="page-title">{esc(work.title)}</h2>
      {work.subtitle && <p class="subtitle">{esc(work.subtitle)}</p>}

      {authors.length > 0 && (
        <div class="authors">
          by {authors.map((a, i) => (
            <span>
              <a href={`/authors/${a.slug}`}>{esc(a.name)}</a>{i < authors.length - 1 && ', '}
            </span>
          ))}
        </div>
      )}

      {work.first_publish_date && (
        <p class="meta">First published: {work.first_publish_date}</p>
      )}
    </div>
  </div>

  {work.description && (
    <section class="description">
      <h2>Description</h2>
      <p>{esc(work.description)}</p>
    </section>
  )}

  <section class="editions">
    <h2>Editions ({editions.length})</h2>
    {editions.length === 0 ? (
      <p class="empty">No editions found</p>
    ) : (
      <div class="editions-list">
        {editions.map(e => (
          <div class="edition">
            {e.cover_id ? (
              <img
                src={`https://covers.openlibrary.org/b/id/${e.cover_id}-S.jpg`}
                alt=""
                width="33"
                height="50"
                class="edition-cover"
                loading="lazy"
              />
            ) : (
              <div class="edition-cover-placeholder" />
            )}
            <div class="edition-info">
              <div class="edition-title">
                {esc(e.title)}
                <ReadingStatus slug={e.slug} client:only="react" />
              </div>
              <div class="edition-meta">
                {e.publishers && <span>{esc(e.publishers)}</span>}
                {e.publish_date && <span> · {e.publish_date}</span>}
                {e.physical_format && <span> · {e.physical_format}</span>}
                {e.number_of_pages && <span> · {e.number_of_pages} pages</span>}
              </div>
            </div>
          </div>
        ))}
      </div>
    )}
  </section>
</Layout>

<style>
  .work-header {
    display: flex;
    gap: 20px;
    margin-bottom: 20px;
  }
  .work-cover {
    width: 120px;
    height: 180px;
    object-fit: cover;
    flex-shrink: 0;
    background: #e8e4d9;
  }
  .work-info {
    flex: 1;
    min-width: 0;
  }
  .page-title {
    font-size: 1.5em;
    margin: 0 0 10px;
  }
  .subtitle {
    font-size: 1.1em;
    font-style: italic;
    color: #5a5549;
    margin: 0 0 15px;
  }
  .authors {
    font-size: 1.1em;
    margin-bottom: 15px;
  }
  .meta {
    font-size: 14px;
    color: #8a8477;
    margin-bottom: 0;
  }
  .description {
    margin-bottom: 30px;
    line-height: 1.6;
  }
  .editions-list {
    border: 1px solid #000;
  }
  .edition {
    display: flex;
    gap: 12px;
    padding: 12px 15px;
    border-bottom: 1px solid #d9d4c8;
    background: #faf6ed;
    align-items: flex-start;
  }
  .edition:last-child { border-bottom: none; }
  .edition:hover { background: #f0ebdf; }
  .edition-cover {
    width: 33px;
    height: 50px;
    object-fit: cover;
    flex-shrink: 0;
    background: #e8e4d9;
  }
  .edition-cover-placeholder {
    width: 33px;
    height: 50px;
    flex-shrink: 0;
    background: #e8e4d9;
  }
  .edition-info {
    flex: 1;
    min-width: 0;
  }
  .edition-title {
    font-weight: 500;
    margin-bottom: 3px;
  }
  .edition-meta {
    font-size: 13px;
    color: #8a8477;
  }
  .empty {
    color: #8a8477;
    padding: 20px;
    text-align: center;
  }
</style>
