---
import Layout from '../../layouts/Layout.astro';
import EditableField from '../../components/EditableField.tsx';

const API_BASE = import.meta.env.API_URL || 'http://localhost:3000';
const { key } = Astro.params;

const authorRes = await fetch(`${API_BASE}/authors/${key}`);
if (!authorRes.ok) {
  return Astro.redirect('/404');
}
const author = await authorRes.json();

let works = [];
try {
  const worksRes = await fetch(`${API_BASE}/authors/${key}/works`);
  if (worksRes.ok) {
    works = (await worksRes.json()).sort((a, b) =>
      (b.ratings_count ?? 0) - (a.ratings_count ?? 0)
    );
  }
} catch (e) {}

// Cache for 1 hour, stale-while-revalidate for 1 day
Astro.response.headers.set('Cache-Control', 'public, max-age=3600, stale-while-revalidate=86400');

const ogDescription = author.bio
  ? author.bio.slice(0, 200) + (author.bio.length > 200 ? '...' : '')
  : `Author of ${works.length} works`;

function esc(str) {
  if (!str) return '';
  return str.replace(/[\uFE20\uFE21]/g, '');
}
---

<Layout title={author.name} description={ogDescription} type="profile" showPortal>
  <EditableField
    value={author.name}
    field="name"
    endpoint={`/authors/${key}`}
    as="h2"
    className="page-title"
    client:only="react"
  />
  <EditableField
    value={author.fuller_name || ''}
    field="fuller_name"
    endpoint={`/authors/${key}`}
    as="p"
    className="fuller-name"
    placeholder="Add full name..."
    client:only="react"
  />

  <div class="meta">
    <EditableField
      value={author.birth_date || ''}
      field="birth_date"
      endpoint={`/authors/${key}`}
      label="Born: "
      placeholder="Add date..."
      client:only="react"
    />
    {(author.birth_date || author.death_date) && <span> · </span>}
    <EditableField
      value={author.death_date || ''}
      field="death_date"
      endpoint={`/authors/${key}`}
      label="Died: "
      placeholder="Add date..."
      client:only="react"
    />
  </div>

  <section class="bio">
    <h2>Biography</h2>
    <EditableField
      value={author.bio || ''}
      field="bio"
      endpoint={`/authors/${key}`}
      as="p"
      multiline
      placeholder="Add biography..."
      client:only="react"
    />
  </section>

  <section class="works">
    <h2>Works ({works.length})</h2>
    {works.length === 0 ? (
      <p class="empty">No works found</p>
    ) : (
      <div class="works-list">
        {works.map(w => (
          <a href={`/works/${w.slug}`} class="work">
            {w.cover_id ? (
              <img
                src={`https://covers.openlibrary.org/b/id/${w.cover_id}-S.jpg`}
                alt=""
                width="33"
                height="50"
                class="work-cover"
                loading="lazy"
              />
            ) : (
              <div class="work-cover-placeholder" />
            )}
            <div class="work-info">
              <div class="work-title">{esc(w.title)}</div>
              {w.subtitle && <div class="work-subtitle">{esc(w.subtitle)}</div>}
              <div class="work-meta">
                {w.first_publish_date && <span>{w.first_publish_date}</span>}
                {w.ratings_count > 0 && (
                  <span>
                    {w.first_publish_date && ' · '}
                    <span class="rating">{w.rating_avg?.toFixed(2)}</span>
                    ({w.ratings_count.toLocaleString()} ratings)
                  </span>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</Layout>

<style>
  .page-title {
    font-size: 1.5em;
    margin: 0 0 10px;
  }
  .fuller-name {
    font-size: 1.1em;
    font-style: italic;
    color: #5a5549;
    margin: 0 0 15px;
  }
  .meta {
    font-size: 14px;
    color: #8a8477;
    margin-bottom: 20px;
  }
  .bio {
    margin-bottom: 30px;
    line-height: 1.6;
  }
  .works-list {
    border: 1px solid #000;
  }
  .work {
    display: flex;
    gap: 12px;
    padding: 12px 15px;
    border-bottom: 1px solid #d9d4c8;
    background: #faf6ed;
    text-decoration: none;
    color: inherit;
    align-items: flex-start;
  }
  .work:last-child { border-bottom: none; }
  .work:hover { background: #f0ebdf; }
  .work-cover {
    width: 33px;
    height: 50px;
    object-fit: cover;
    flex-shrink: 0;
    background: #e8e4d9;
  }
  .work-cover-placeholder {
    width: 33px;
    height: 50px;
    flex-shrink: 0;
    background: #e8e4d9;
  }
  .work-info {
    flex: 1;
    min-width: 0;
  }
  .work-title {
    font-weight: 500;
    margin-bottom: 2px;
  }
  .work-subtitle {
    font-size: 14px;
    font-style: italic;
    color: #5a5549;
  }
  .work-meta {
    font-size: 13px;
    color: #8a8477;
    margin-top: 3px;
  }
  .rating {
    color: #b8860b;
    font-weight: 500;
  }
  .empty {
    color: #8a8477;
    padding: 20px;
    text-align: center;
  }
</style>
