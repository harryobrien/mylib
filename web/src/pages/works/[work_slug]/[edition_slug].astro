---
import Layout from '../../../layouts/Layout.astro';
import ReadingStatus from '../../../components/ReadingStatus.tsx';
import EditableField from '../../../components/EditableField.tsx';

const API_BASE = import.meta.env.API_URL || 'http://localhost:3000';
const { work_slug, edition_slug } = Astro.params;

// Fetch work and edition data in parallel
const [workRes, editionRes] = await Promise.all([
  fetch(`${API_BASE}/works/${work_slug}`),
  fetch(`${API_BASE}/editions/${edition_slug}`)
]);

if (!workRes.ok || !editionRes.ok) {
  return Astro.redirect('/404');
}

const { authors, editions: unsortedEditions, popularity, ...work } = await workRes.json();
const edition = await editionRes.json();

// Verify edition belongs to this work
if (edition.work_id !== work.id) {
  return Astro.redirect(`/works/${work_slug}`);
}

const editions = unsortedEditions.sort((a, b) =>
  (b.popularity?.ratings_count ?? 0) - (a.popularity?.ratings_count ?? 0)
);

const coverId = edition.cover_id || edition.covers?.[0]?.id;
const ogImage = coverId ? `https://covers.openlibrary.org/b/id/${coverId}-L.jpg` : undefined;
const authorList = authors.map(a => a.name).join(', ');
const ogDescription = work.description
  ? work.description.slice(0, 200) + (work.description.length > 200 ? '...' : '')
  : authorList ? `By ${authorList}` : undefined;

// Cache for 1 hour, stale-while-revalidate for 1 day
Astro.response.headers.set('Cache-Control', 'public, max-age=3600, stale-while-revalidate=86400');

function esc(str) {
  if (!str) return '';
  return str.replace(/[\uFE20\uFE21]/g, '');
}
---

<Layout title={`${edition.title} - ${work.title}`} description={ogDescription} image={ogImage} type="book" showPortal>
  <div class="work-header">
    {coverId ? (
      <img
        src={`https://covers.openlibrary.org/b/id/${coverId}-M.jpg`}
        alt=""
        width="120"
        height="180"
        class="work-cover"
      />
    ) : (
      <div class="work-cover-placeholder" />
    )}
    <div class="work-info">
      <EditableField
        value={edition.title}
        field="title"
        endpoint={`/editions/${edition_slug}`}
        as="h2"
        className="page-title"
        client:only="react"
      />
      <EditableField
        value={edition.subtitle || ''}
        field="subtitle"
        endpoint={`/editions/${edition_slug}`}
        as="p"
        className="subtitle"
        placeholder="Add subtitle..."
        client:only="react"
      />

      {authors.length > 0 && (
        <div class="authors">
          by {authors.map((a, i) => (
            <span>
              <a href={`/authors/${a.slug}`}>{esc(a.name)}</a>{i < authors.length - 1 && ', '}
            </span>
          ))}
        </div>
      )}

      <div class="edition-details">
        {edition.publishers && <p class="meta"><strong>Publisher:</strong> {esc(edition.publishers)}</p>}
        <EditableField
          value={edition.publish_date || ''}
          field="publish_date"
          endpoint={`/editions/${edition_slug}`}
          as="p"
          className="meta"
          label="Published: "
          placeholder="Add date..."
          client:only="react"
        />
        <EditableField
          value={edition.physical_format || ''}
          field="physical_format"
          endpoint={`/editions/${edition_slug}`}
          as="p"
          className="meta"
          label="Format: "
          placeholder="Add format..."
          client:only="react"
        />
        <EditableField
          value={edition.number_of_pages?.toString() || ''}
          field="number_of_pages"
          endpoint={`/editions/${edition_slug}`}
          as="p"
          className="meta"
          label="Pages: "
          placeholder="Add page count..."
          client:only="react"
        />
        {edition.isbns?.length > 0 && (
          <p class="meta"><strong>ISBN:</strong> {edition.isbns.join(', ')}</p>
        )}
      </div>

      {edition.popularity?.ratings_count > 0 && (
        <div class="ratings">
          <span class="rating-value">{edition.popularity.rating_avg?.toFixed(2)}</span>
          <span class="rating-count">({edition.popularity.ratings_count.toLocaleString()} ratings)</span>
        </div>
      )}

      <div class="reading-status-container">
        <ReadingStatus slug={edition_slug} client:only="react" />
      </div>
    </div>
  </div>

  {work.description && (
    <section class="description">
      <h2>Description</h2>
      <p>{esc(work.description)}</p>
    </section>
  )}

  <section class="editions">
    <h2>
      <a href={`/works/${work_slug}`} class="work-link">All Editions ({editions.length})</a>
    </h2>
    {editions.length === 0 ? (
      <p class="empty">No editions found</p>
    ) : (
      <div class="editions-list">
        {editions.map(e => (
          <a
            href={`/works/${work_slug}/${e.slug}`}
            class:list={["edition", { selected: e.slug === edition_slug }]}
          >
            {e.cover_id ? (
              <img
                src={`https://covers.openlibrary.org/b/id/${e.cover_id}-S.jpg`}
                alt=""
                width="33"
                height="50"
                class="edition-cover"
                loading="lazy"
              />
            ) : (
              <div class="edition-cover-placeholder" />
            )}
            <div class="edition-info">
              <div class="edition-title">{esc(e.title)}</div>
              <div class="edition-meta">
                {e.publishers && <span>{esc(e.publishers)}</span>}
                {e.publish_date && <span> · {e.publish_date}</span>}
                {e.physical_format && <span> · {e.physical_format}</span>}
                {e.number_of_pages && <span> · {e.number_of_pages} pages</span>}
                {e.popularity?.ratings_count > 0 && (
                  <span> · <span class="edition-rating">{e.popularity.rating_avg?.toFixed(1)}</span> ({e.popularity.ratings_count.toLocaleString()})</span>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</Layout>

<style>
  .work-header {
    display: flex;
    gap: 20px;
    margin-bottom: 20px;
  }
  .work-cover {
    width: 120px;
    height: 180px;
    object-fit: cover;
    flex-shrink: 0;
    background: #e8e4d9;
  }
  .work-cover-placeholder {
    width: 120px;
    height: 180px;
    flex-shrink: 0;
    background: #e8e4d9;
  }
  .work-info {
    flex: 1;
    min-width: 0;
  }
  .page-title {
    font-size: 1.5em;
    margin: 0 0 10px;
  }
  .subtitle {
    font-size: 1.1em;
    font-style: italic;
    color: #5a5549;
    margin: 0 0 15px;
  }
  .authors {
    font-size: 1.1em;
    margin-bottom: 15px;
  }
  .edition-details {
    margin-bottom: 12px;
  }
  .edition-details .meta {
    font-size: 14px;
    color: #5a5549;
    margin: 4px 0;
  }
  .edition-details strong {
    color: #3a3530;
  }
  .ratings {
    margin-top: 12px;
    font-size: 14px;
  }
  .rating-value {
    color: #b8860b;
    font-weight: 500;
    font-size: 1.1em;
  }
  .rating-count {
    color: #8a8477;
    margin-left: 4px;
  }
  .reading-status-container {
    margin-top: 15px;
  }
  .description {
    margin-bottom: 30px;
    line-height: 1.6;
  }
  .work-link {
    color: inherit;
    text-decoration: none;
  }
  .work-link:hover {
    text-decoration: underline;
  }
  .editions-list {
    border: 1px solid #000;
  }
  .edition {
    display: flex;
    gap: 12px;
    padding: 12px 15px;
    border-bottom: 1px solid #d9d4c8;
    background: #faf6ed;
    align-items: flex-start;
    text-decoration: none;
    color: inherit;
  }
  .edition:last-child { border-bottom: none; }
  .edition:hover { background: #f0ebdf; }
  .edition.selected {
    background: #e8e4d9;
    border-left: 3px solid #b8860b;
    padding-left: 12px;
  }
  .edition-cover {
    width: 33px;
    height: 50px;
    object-fit: cover;
    flex-shrink: 0;
    background: #e8e4d9;
  }
  .edition-cover-placeholder {
    width: 33px;
    height: 50px;
    flex-shrink: 0;
    background: #e8e4d9;
  }
  .edition-info {
    flex: 1;
    min-width: 0;
  }
  .edition-title {
    font-weight: 500;
    margin-bottom: 3px;
  }
  .edition-meta {
    font-size: 13px;
    color: #8a8477;
  }
  .edition-rating {
    color: #b8860b;
    font-weight: 500;
  }
  .empty {
    color: #8a8477;
    padding: 20px;
    text-align: center;
  }
</style>
